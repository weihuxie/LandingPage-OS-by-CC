# Platform-hosted LLM keys (PRD v5.1 §2) — users never configure these.
# If any of these are missing, the corresponding adapter falls back to
# deterministic templated output. No hard dependency.

# Claude (Sonnet) — structured JSON copywriting + module generation
ANTHROPIC_API_KEY=

# Gemini 1.5 Pro — long document ingestion (whitepapers, manuals)
GOOGLE_API_KEY=

# GPT-4o — multilingual cultural localization
OPENAI_API_KEY=

# Vercel — one-click deploy of user's landing pages (PRD v5.1 §6)
# Missing token → deploy endpoint returns a mock URL instead of calling Vercel.
#
# NOTE: VERCEL_* prefix is reserved by Vercel for system env vars, so we use VC_*.
VC_API_TOKEN=
# Optional — scope deployments to a Vercel team instead of personal account.
VC_TEAM_ID=
